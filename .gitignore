# ====================================================================
# Global / OS / IDEs
# ====================================================================
.DS_Store
Thumbs.db
desktop.ini
*.log
*.tmp

# VS Code
.vscode/
!.vscode/extensions.json
!.vscode/launch.json
!.vscode/tasks.json

# JetBrains Rider / IntelliJ
.idea/
*.sln.iml
*.suo
*.user
*.userosscache
*.sln.docstates
